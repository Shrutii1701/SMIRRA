{
  "name": "smirra",
  "version": "1.0.0",
  "description": "Gamified AI-powered interview preparation platform",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}